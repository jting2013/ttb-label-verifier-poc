APP_NAME=AI-Powered Alcohol Label Verification App
ENVIRONMENT=local
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./ttb_label_review.db
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=20
PERSIST_RESULTS=true
DELETE_UPLOADS_AFTER_PROCESSING=true
OCR_ENGINE=tesseract
EASYOCR_LANGUAGES=en
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
EXPECTED_DATA_PATH=../sample_data/expected/mock_applications.json
